generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Language {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  icon       String?
  categories String[]
  topics     Topic[]
  createdAt  DateTime @default(now())
}

model Topic {
  id         String        @id @default(cuid())
  title      String
  slug       String
  languageId String
  language   Language      @relation(fields: [languageId], references: [id])
  order      Int
  sessions   QuizSession[]
  createdAt  DateTime      @default(now())

  @@unique([languageId, slug])
  @@index([languageId, order])
}

model QuizSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  languageId  String
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id])
  difficulty  String
  score       Int
  total       Int
  answers     Json
  completedAt DateTime @default(now())

  @@index([userId, completedAt])
  @@index([topicId, completedAt])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  password     String?
  image        String?
  sessions     QuizSession[]
  accounts     Account[]
  authSessions Session[]
  streak       Int           @default(0)
  lastActiveAt DateTime?
  createdAt    DateTime      @default(now())
}

// NextAuth.js models for PrismaAdapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

